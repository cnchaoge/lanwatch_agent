# 服务端环境变量配置示例
# 复制此文件为 .env 并填入实际值

# Server酱 Webhook（告警推送）
SCKEY=

# 管理后台密码
ADMIN_PASSWORD=admin

# CORS 允许的来源（逗号分隔，留空则同源）
# 示例：https://example.com,https://app.example.com
CORS_ORIGINS=

# 数据库路径
DB_PATH=monitor.db

# 日志级别 (DEBUG / INFO / WARNING / ERROR)
LOG_LEVEL=INFO

# 数据保留天数（到期自动清理）
RETENTION_PROBE_DAYS=5    # 探测日志保留 5 天
RETENTION_SNMP_DAYS=5     # SNMP 指标保留 5 天
RETENTION_ALERT_DAYS=30   # 告警日志保留 30 天
RETENTION_DIAG_DAYS=30    # 诊断报告保留 30 天
