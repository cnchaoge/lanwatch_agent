#!/bin/sh /etc/rc.common
# LanWatch OpenWrt init script

START=95
STOP=10
USE_PROCD=1

PROG="/usr/bin/lanwatch_router_agent.sh"
NAME="lanwatch"

boot() {
    start
}

start_service() {
    [ -x "$PROG" ] || {
        echo "lanwatch agent not found: $PROG"
        return 1
    }

    procd_open_instance
    procd_set_param command "$PROG" run
    procd_set_param respawn 3600 5 5
    procd_set_param stdout 1
    procd_set_param stderr 1
    procd_close_instance
}

service_triggers() {
    procd_add_reload_trigger "lanwatch"
}
